###############################################################################
# Zava AI Agents Workshop — environment variables
# Copy this file to `.env` and fill in the values from your pre-provisioned
# Azure resources (see docs/00_setup/00_03_verify_resources.md).
###############################################################################

# -------- Azure subscription & tenant (used by DefaultAzureCredential) -------
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=

# ------------------------ Microsoft Foundry project -------------------------
# Example: https://<resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_PROJECT_NAME=
# Model deployment name on the Foundry project (e.g. gpt-4.1, gpt-4.1-mini, gpt-4o)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4.1-mini

# Foundry project ARM resource id (used to create connections via ARM REST)
# /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<acct>/projects/<proj>
AZURE_AI_PROJECT_RESOURCE_ID=

# ------------------------ Foundry IQ / Azure AI Search -----------------------
# Example: https://<search-service>.search.windows.net
AZURE_SEARCH_ENDPOINT=
STORE_OPS_KB_NAME=zava-store-ops-kb
STORE_OPS_KB_SOURCE_ID=zava-store-ops-source
STORE_OPS_KB_CONNECTION_NAME=zava-store-ops-kb-conn
MARKETING_KB_NAME=zava-marketing-kb
MARKETING_KB_SOURCE_ID=zava-marketing-source
MARKETING_KB_CONNECTION_NAME=zava-marketing-kb-conn
MARKETING_TOOLBOX_NAME=zava-marketing-tools

# --------------------------- Azure Cosmos DB --------------------------------
# Example: https://<account>.documents.azure.com:443/
COSMOS_ENDPOINT=
COSMOS_DATABASE=zava
COSMOS_PRODUCTS_CONTAINER=products
COSMOS_MARKETING_CONTAINER=marketing_campaigns

# -------------- MCP server endpoints (filled in after Ex. 02 & 04) ----------
# Example: https://zava-products-mcp.<env>.azurecontainerapps.io/mcp
PRODUCTS_MCP_URL=
PRODUCTS_MCP_CONNECTION_NAME=zava-products-mcp-conn
MARKETING_MCP_URL=
MARKETING_MCP_CONNECTION_NAME=zava-marketing-mcp-conn

# ---------------- Bing Grounding (legacy — only needed if you keep the
# old Module 05 Prompt Agent variant; the new hosted Marketing agent uses
# the Foundry Toolbox web_search tool instead).
BING_GROUNDING_CONNECTION_NAME=zava-bing-grounding

# ------- Foundry hosted-agent runtime variables (Exercise 05) ---------------
# Auto-injected by Foundry at runtime: FOUNDRY_PROJECT_ENDPOINT,
# APPLICATIONINSIGHTS_CONNECTION_STRING. Do NOT set FOUNDRY_* / AGENT_* in
# agent.yaml.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_AI_SEARCH_SERVICE_ENDPOINT=
AZURE_AI_SEARCH_KNOWLEDGE_BASE_NAME=zava-marketing-kb
CUSTOM_FOUNDRY_AGENT_TOOLBOX_NAME=zava-marketing-tools

# ---------------- Foundry agent names (created by scripts) ------------------
STORE_OPS_AGENT_NAME=zava-store-ops-agent
PRODUCTS_AGENT_NAME=zava-products-agent
MARKETING_AGENT_NAME=zava-marketing-agent
RESPONSE_AGENT_NAME=zava-response-generator

# --------------- Azure Container Apps (for MCP server deploy) ---------------
ACA_ENVIRONMENT=zava-aca-env
ACA_LOCATION=eastus2
ACR_NAME=

# ----------------- Observability (Exercise 11 only — leave blank) -----------
# Populated in Exercise 11. Modules 01-08 do not need these.
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=zava-agents-workshop

# ------------------------ DevUI launcher (optional) -------------------------
# Override the host/port used by `python -m src.app.devui_launch`.
DEVUI_HOST=127.0.0.1
DEVUI_PORT=8080
