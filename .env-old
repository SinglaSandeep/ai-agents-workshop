###############################################################################
# Pepsico AI Agents Workshop — environment variables
# Copy this file to `.env` and fill in the values from your pre-provisioned
# Azure resources (see docs/00_setup/00_03_verify_resources.md).
###############################################################################

# -------- Azure subscription & tenant (used by DefaultAzureCredential) -------
AZURE_SUBSCRIPTION_ID=a6ea71fd-9e0d-4dcb-8e82-56013d00b46d
AZURE_TENANT_ID=bc533d40-04b1-4d28-bbca-13e7c8b0d125
AZURE_RESOURCE_GROUP=aifounry-rg

# ------------------------ Microsoft Foundry project -------------------------
# Example: https://<resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://foundry-workshop-sc.services.ai.azure.com/api/projects/proj-workshop
AZURE_AI_PROJECT_NAME=
# Model deployment name on the Foundry project (e.g. gpt-4.1, gpt-4.1-mini, gpt-4o)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4.1

# Foundry project ARM resource id (used to create connections via ARM REST)
# /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<acct>/projects/<proj>
AZURE_AI_PROJECT_RESOURCE_ID=/subscriptions/a6ea71fd-9e0d-4dcb-8e82-56013d00b46d/resourceGroups/rg-workshop/providers/Microsoft.CognitiveServices/accounts/foundry-workshop-sc/projects/proj-workshop

# ------------------------ Foundry IQ / Azure AI Search -----------------------
# Example: https://<search-service>.search.windows.net
AZURE_SEARCH_ENDPOINT=
HR_KB_NAME=pepsico-hr-kb
HR_KB_SOURCE_ID=pepsico-hr-source
HR_KB_CONNECTION_NAME=pepsico-hr-kb-conn

# --------------------------- Azure Cosmos DB --------------------------------
# Example: https://<account>.documents.azure.com:443/
COSMOS_ENDPOINT=https://cosmos-ai-2025.documents.azure.com:443/
COSMOS_DATABASE=pepsico
COSMOS_PRODUCTS_CONTAINER=products
COSMOS_MARKETING_CONTAINER=marketing_campaigns

# -------------- MCP server endpoints (filled in after Ex. 01 & 02) ----------
# Example: https://pepsico-products-mcp.<env>.azurecontainerapps.io/mcp
PRODUCTS_MCP_URL=https://pepsico-products-mcp.mangowave-c2bab563.swedencentral.azurecontainerapps.io/mcp
PRODUCTS_MCP_CONNECTION_NAME=pepsico-products-mcp-conn
MARKETING_MCP_URL=
https://pepsico-marketing-mcp.mangowave-c2bab563.swedencentral.azurecontainerapps.io/mcp
MARKETING_MCP_CONNECTION_NAME=pepsico-marketing-mcp-conn

# ---------------- Bing Grounding (Foundry connection name) ------------------
# The display name of the Grounding-with-Bing-Search connection registered
# on your Foundry project (Exercise 05).
BING_GROUNDING_CONNECTION_NAME=pepsico-bing-grounding

# ---------------- Foundry agent names (created by scripts) ------------------
HR_AGENT_NAME=pepsico-hr-agent
PRODUCTS_AGENT_NAME=pepsico-products-agent
MARKETING_AGENT_NAME=pepsico-marketing-agent
RESPONSE_AGENT_NAME=pepsico-response-generator

# --------------- Azure Container Apps (for MCP server deploy) ---------------
ACA_ENVIRONMENT=pepsico-aca-env
ACA_LOCATION=swedencentral
ACR_NAME=acrregistry2025

# ---------------------- Observability (optional) ----------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=pepsico-agents-workshop

# ------------------------ Chat app backend mode -----------------------------
# Controls which backend `src/app/main.py` routes /chat to.
#   stub          (Exercise 01 default) — hard-coded reply
#   products      (Exercise 03) — single Products Foundry agent
#   marketing     (Exercise 05) — single Marketing Foundry agent
#   hr            (Exercise 06) — single HR Foundry agent
#   orchestrator  (Exercise 07+) — Magnetic multi-agent orchestrator
AGENT_MODE=products

