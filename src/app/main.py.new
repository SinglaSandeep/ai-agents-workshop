"""FastAPI chat application for the Pepsico multi-agent assistant.

This file evolves across the workshop:

* **Exercise 01** — runs as-is and returns a hard-coded stub answer so you can
  see the UI immediately.
* **Exercise 03** — you wire in the Products agent (`AGENT_MODE=products`).
* **Exercise 05** — you wire in the Marketing agent (`AGENT_MODE=marketing`).
* **Exercise 06** — you wire in the HR agent (`AGENT_MODE=hr`).
* **Exercise 07** — you switch to the Magentic orchestrator
  (`AGENT_MODE=orchestrator`) which routes across all three.
"""

from __future__ import annotations

import os
from pathlib import Path

from dotenv import load_dotenv
from fastapi import FastAPI
from fastapi.responses import HTMLResponse, JSONResponse
from pydantic import BaseModel, Field

from src.common.observability import configure_observability, trace_span

load_dotenv()

app = FastAPI(title="Pepsico AI Agents Workshop", version="1.0.0")
observability_enabled = configure_observability(app)
_CHAT_HTML = (Path(__file__).with_name("chat.html")).read_text(encoding="utf-8")

# AGENT_MODE controls which backend handles /chat. As you complete each
# exercise, set the value in `.env` (or the OS environment) to the next stage.
#   stub          (default)  — Exercise 01: hard-coded reply
#   products                 — Exercise 03: single Products Foundry agent
#   marketing                — Exercise 05: single Marketing Foundry agent
#   hr                       — Exercise 06: single HR Foundry agent
#   orchestrator             — Exercise 07+: Magentic multi-agent orchestrator
AGENT_MODE = os.getenv("AGENT_MODE", "stub").lower()


class ChatRequest(BaseModel):
    query: str = Field(..., min_length=1, examples=["What is our PTO policy?"])


class ChatResponse(BaseModel):
    final_answer: str
    plan: list[str] = []
    transcripts: dict[str, str] = {}
    events: list[dict] = []
    mode: str = AGENT_MODE


@app.get("/health")
def health() -> dict[str, object]:
    return {
        "status": "ok",
        "agent_mode": AGENT_MODE,
        "observability_enabled": observability_enabled,
    }


@app.post("/chat", response_model=ChatResponse)
async def chat(request: ChatRequest) -> JSONResponse:
    with trace_span("pepsico.chat", query=request.query, mode=AGENT_MODE):
        result = await _dispatch(request.query)
    return JSONResponse(result)


async def _dispatch(query: str) -> dict:
    """Route the user query to the backend configured by `AGENT_MODE`."""

    if AGENT_MODE == "stub":
        return _stub_response(query)

    if AGENT_MODE in {"products", "marketing", "hr"}:
        # TODO (Exercises 03 / 05 / 06): replace this stub with a call to the
        # single-agent runner you build in `src/foundry_agents/run_single_agent.py`.
        # Example:
        #
        #   from src.foundry_agents.run_single_agent import run_single_agent
        #   answer = await run_single_agent(AGENT_MODE, query)
        #   return {
        #       "final_answer": answer,
        #       "plan": [AGENT_MODE],
        #       "transcripts": {AGENT_MODE: answer},
        #       "events": [],
        #       "mode": AGENT_MODE,
        #   }
        return _not_yet_wired(query, AGENT_MODE)

    if AGENT_MODE == "orchestrator":
        # TODO (Exercise 07): replace this stub with the Magentic orchestrator.
        #
        #   from src.orchestrator.magentic_router import run_query
        #   result = await run_query(query)
        #   return {
        #       "final_answer": result.final_answer,
        #       "plan": result.plan,
        #       "transcripts": result.transcripts,
        #       "events": result.events,
        #       "mode": AGENT_MODE,
        #   }
        return _not_yet_wired(query, AGENT_MODE)

    return _stub_response(query)


def _stub_response(query: str) -> dict:
    return {
        "final_answer": (
            "This application is not yet ready to serve results. Please check "
            "back later. (You are seeing the Exercise 01 stub — set `AGENT_MODE` "
            "in `.env` after each exercise to wire in a real agent.)"
        ),
        "plan": ["stub"],
        "transcripts": {"stub": f"Echo of your question: {query}"},
        "events": [],
        "mode": AGENT_MODE,
    }


def _not_yet_wired(query: str, mode: str) -> dict:
    return {
        "final_answer": (
            f"AGENT_MODE is set to `{mode}` but the matching exercise code "
            "has not been wired in yet. Open `src/app/main.py` and follow the "
            f"TODO for the `{mode}` branch."
        ),
        "plan": [mode],
        "transcripts": {mode: f"(unwired) you asked: {query}"},
        "events": [],
        "mode": mode,
    }


@app.get("/", response_class=HTMLResponse)
def index() -> str:
    return _CHAT_HTML
